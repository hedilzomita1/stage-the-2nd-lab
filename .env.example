# --- LLM ---
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# --- Neo4j ---
# Set cloud mode to avoid Docker on end-user machines:
# AEBM_NEO4J_MODE=cloud
# NEO4J_URI=neo4j+s://YOUR_AURA_INSTANCE_ID.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=YOUR_AURA_PASSWORD

# Local mode (default):
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_CONTAINER=neo4j-aebm

# --- PII Vault (optional override) ---
# If empty, the app can generate/load a local key near the vault file.
PII_VAULT_KEY=
PII_VAULT_KEY_PATH=
